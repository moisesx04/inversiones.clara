// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        String   @id @default(uuid())
  name      String
  phone     String
  document  String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())
  loans     Loan[]

  @@map("clients")
}

model Loan {
  id           String    @id @default(uuid())
  clientId     String
  principal    Float
  reengagedCapital Float @default(0)
  interestRate Float
  total        Float
  installments Int
  frequency    String
  startDate    String
  createdAt    DateTime  @default(now())
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@map("loans")
}

model Payment {
  id      String  @id @default(uuid())
  loanId  String
  number  Int
  dueDate String
  amount  Float
  paid         Boolean @default(false)
  paidAt       String  @default("")
  paidInterest Float?
  paidCapital  Float?
  loan         Loan    @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model SanGroup {
  id               String       @id @default(uuid())
  name             String
  quotaAmount      Float
  frequency        String
  startDate        String
  participantCount Int
  status           String
  createdAt        DateTime     @default(now())
  clients          SanClient[]
  payments         SanPayment[]

  @@map("san_groups")
}

model SanClient {
  id         String       @id @default(uuid())
  sanId      String
  name       String
  phone      String
  document   String       @default("")
  turnNumber Int
  status     String
  notes      String       @default("")
  san        SanGroup     @relation(fields: [sanId], references: [id], onDelete: Cascade)
  payments   SanPayment[]

  @@map("san_clients")
}

model SanPayment {
  id          String    @id @default(uuid())
  sanId       String
  sanClientId String
  roundNumber Int
  amount      Float
  paidAt      String
  san         SanGroup  @relation(fields: [sanId], references: [id], onDelete: Cascade)
  client      SanClient @relation(fields: [sanClientId], references: [id], onDelete: Cascade)

  @@map("san_payments")
}
