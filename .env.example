# ─── Auth ────────────────────────────────────────────────────────
# Usuario y clave para entrar al sistema
CLARA_USER=admin
CLARA_PASSWORD=admin123

# ─── PostgreSQL ──────────────────────────────────────────────────
# Formato: postgresql://USUARIO:CLAVE@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://clara_user:TU_CLAVE_AQUI@localhost:5432/clara_db"

# ─── Next.js ─────────────────────────────────────────────────────
# Puerto en el que corre la app (en el VPS será 3015)
PORT=3015
